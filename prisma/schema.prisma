generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id String @id @default(cuid())

  name String

  email String @unique

  password String

  phone String?

  whatsapp String

  avatar String?

  department Department @default(MANAGEMENT)

  role EmployeeRole @default(EMPLOYEE)

  designation String?

  employeeCode String? @unique

  joiningDate DateTime?

  reportingToId String?

  address String?

  emergencyName String?

  emergencyPhone String?

  isActive Boolean @default(true)

  lastLogin DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

 reportingTo Employee? @relation("EmployeeManager", fields: [reportingToId], references: [id])

team Employee[] @relation("EmployeeManager")

  leads Lead[]

  followups FollowUp[]

  meetings Meeting[]

  orders Order[]

  tasks Task[]

  notifications Notification[]

  uploadedMedia LeadMedia[]

  callRecordings CallRecording[]
}

model Lead {
  id              String          @id @default(cuid())
  customer_name   String
  phone_number    String
  email           String?
  city            String?
  meta_lead_id    String?
  ad_id           String?
  created_time    DateTime?
  location_detail String?
  timeline        String?
  area            String?
  lead_status     String          @default("CREATED")
  assignedToId    String?
  nextFollowUp    DateTime?
  siteVisitDate   DateTime?
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  priority        String?
  tags            String?
  stage           LeadStage       @default(NEW)
  activities      Activity[]
  callRecordings  CallRecording[]
  followups       FollowUp[]
  assignedTo      Employee?       @relation(fields: [assignedToId], references: [id])
  media           LeadMedia[]
  meetings        Meeting[]
  orders          Order[]
  tasks           Task[]
}

model Activity {
  id          String   @id @default(cuid())
  leadId      String
  type        String
  oldStatus   String?
  newStatus   String?
  note        String?
  performedBy String?
  createdAt   DateTime @default(now())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model FollowUp {
  id           String         @id @default(cuid())
  followupDate DateTime
  remarks      String?
  status       FollowUpStatus @default(PENDING)
  reminderSent Boolean        @default(false)
  leadId       String
  employeeId   String
  createdAt    DateTime       @default(now())
  employee     Employee       @relation(fields: [employeeId], references: [id])
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Meeting {
  id            String        @id @default(cuid())
  meetingDate   DateTime
  notes         String?
  status        MeetingStatus @default(SCHEDULED)
  googleEventId String?
  duration      Int?          @default(30)
  leadId        String
  employeeId    String
  createdAt     DateTime      @default(now())
  employee      Employee      @relation(fields: [employeeId], references: [id])
  lead          Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Order {
  id         String      @id @default(cuid())
  amount     Float?
  status     OrderStatus @default(PENDING)
  remarks    String?
  leadId     String
  employeeId String
  createdAt  DateTime    @default(now())
  employee   Employee    @relation(fields: [employeeId], references: [id])
  lead       Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String           @id @default(cuid())
  title      String
  message    String
  isRead     Boolean          @default(false)
  type       NotificationType @default(INFO)
  employeeId String?
  createdAt  DateTime         @default(now())
  employee   Employee?        @relation(fields: [employeeId], references: [id])
}

model Task {
  id            String     @id @default(cuid())
  title         String
  description   String?
  type          TaskType
  status        TaskStatus @default(PENDING)
  leadId        String
  employeeId    String
  scheduledAt   DateTime
  googleEventId String?
  acceptedAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  employee      Employee   @relation(fields: [employeeId], references: [id])
  lead          Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadMedia {
  id           String        @id @default(cuid())
  leadId       String
  uploadedById String?
  type         LeadMediaType
  fileName     String
  fileUrl      String
  fileSize     Int?
  caption      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  lead         Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  uploadedBy   Employee?     @relation(fields: [uploadedById], references: [id])
}

model CallRecording {
  id           String        @id @default(cuid())
  leadId       String
  employeeId   String?
  phoneNumber  String
  direction    CallDirection
  duration     Int           @default(0)
  recordingUrl String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  employee     Employee?     @relation(fields: [employeeId], references: [id])
  lead         Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

enum CallDirection {
  INCOMING
  OUTGOING
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum LeadStage {
  NEW
  CALL_SCHEDULED
  FOLLOWUP
  MEETING_FIXED
  SITE_VISIT
  CONFIRMED
  REJECTED
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  MISSED
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum TaskType {
  CALL
  FOLLOWUP
  MEETING
  SITE_VISIT
}

enum TaskStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

enum LeadMediaType {
  PHOTO
  VIDEO
  AUDIO
  DOCUMENT
}

enum Department {
  MANAGEMENT
  SALES
  DESIGN
  HR
  ACCOUNTS
  SUPPORT
  MARKETING
  IT
}

enum EmployeeRole {
  SUPER_ADMIN

  ADMIN

  MANAGER

  SALES_MANAGER

  SALES_EXECUTIVE

  DESIGN_MANAGER

  DESIGNER

  HR_MANAGER

  HR_EXECUTIVE

  ACCOUNT_MANAGER

  ACCOUNT_EXECUTIVE

  SUPPORT

  EMPLOYEE
}
