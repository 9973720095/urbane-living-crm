generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id          String   @id @default(cuid())
  name        String
  email       String
  whatsapp    String
  createdAt   DateTime @default(now())
  designation String?
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  followups FollowUp[]
  leads     Lead[]
  meetings  Meeting[]
  orders    Order[]

  // Existing
  tasks         Task[]
  notifications Notification[]

  // NEW
  uploadedMedia LeadMedia[]
}

model Lead {
  id              String    @id @default(cuid())
  customer_name   String
  phone_number    String
  email           String?
  city            String?
  meta_lead_id    String?
  ad_id           String?
  created_time    DateTime?
  location_detail String?
  timeline        String?
  area            String?

  lead_status   String    @default("CREATED")
  assignedToId  String?
  nextFollowUp  DateTime?
  siteVisitDate DateTime?
  remarks       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priority String?
  tags     String?

  stage LeadStage @default(NEW)

  activities Activity[]
  followups  FollowUp[]
  meetings   Meeting[]
  orders     Order[]

  assignedTo Employee? @relation(fields: [assignedToId], references: [id])

  // Existing
  tasks Task[]

  // NEW
  media LeadMedia[]
}

model Activity {
  id          String   @id @default(cuid())
  leadId      String
  type        String
  oldStatus   String?
  newStatus   String?
  note        String?
  performedBy String?
  createdAt   DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model FollowUp {
  id           String         @id @default(cuid())
  followupDate DateTime
  remarks      String?
  status       FollowUpStatus @default(PENDING)

  reminderSent Boolean @default(false)

  leadId     String
  employeeId String

  createdAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Meeting {
  id            String        @id @default(cuid())
  meetingDate   DateTime
  notes         String?
  status        MeetingStatus @default(SCHEDULED)
  googleEventId String?

  duration Int? @default(30)

  leadId     String
  employeeId String

  createdAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Order {
  id      String      @id @default(cuid())
  amount  Float?
  status  OrderStatus @default(PENDING)
  remarks String?

  leadId     String
  employeeId String

  createdAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Notification {
  id      String           @id @default(cuid())
  title   String
  message String
  isRead  Boolean          @default(false)
  type    NotificationType @default(INFO)

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
}
model Task {
  id String @id @default(cuid())

  title       String
  description String?

  type   TaskType
  status TaskStatus @default(PENDING)

  leadId     String
  employeeId String

  scheduledAt DateTime

  googleEventId String?

  acceptedAt  DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])
}

//
// ======================================
// CUSTOMER PROFILE MEDIA
// ======================================
//

model LeadMedia {
  id String @id @default(cuid())

  leadId String

  uploadedById String?

  type LeadMediaType

  fileName String

  fileUrl String

  fileSize Int?

  caption String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  uploadedBy Employee? @relation(fields: [uploadedById],references: [id])
}

//
// ======================================
// ENUMS
// ======================================
//

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum LeadStage {
  NEW
  CALL_SCHEDULED
  FOLLOWUP
  MEETING_FIXED
  SITE_VISIT
  CONFIRMED
  REJECTED
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  MISSED
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum TaskType {
  CALL
  FOLLOWUP
  MEETING
  SITE_VISIT
}

enum TaskStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

//
// Lead Profile Media Types
//

enum LeadMediaType {
  PHOTO
  VIDEO
  AUDIO
  DOCUMENT
}